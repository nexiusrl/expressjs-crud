<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Data Pegawai — CRUD Pegawai</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=Playfair+Display:wght@400;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream:       #faf8f5;
      --cream-dark:  #f5f0e8;
      --terracotta:  #c0622f;
      --terra-dark:  #a3521f;
      --warm-brown:  #8b4513;
      --sage:        #6b7c5c;
      --text-dark:   #2c2418;
      --text-mid:    #5a4a38;
      --text-light:  #9c8878;
      --border:      #e8dfd4;
      --shadow:      rgba(139,69,19,0.08);
      --shadow-md:   rgba(139,69,19,0.14);
      --white:       #ffffff;
      --radius:      12px;
      --radius-sm:   8px;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background-color: var(--cream);
      color: var(--text-dark);
      min-height: 100vh;
    }

    /* ── Navbar ── */
    .navbar {
      background: var(--white);
      border-bottom: 2px solid var(--terracotta);
      padding: 0 32px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 12px var(--shadow);
    }

    .navbar-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }

    .navbar-brand .dot {
      width: 32px;
      height: 32px;
      background: var(--terracotta);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .navbar-brand .dot i { color: var(--white); font-size: 16px; }

    .navbar-brand span {
      font-family: 'Playfair Display', serif;
      font-size: 1.125rem;
      font-weight: 600;
      color: var(--text-dark);
    }

    .navbar-right {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .nav-user {
      font-size: 0.875rem;
      color: var(--text-mid);
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .nav-user i { color: var(--terracotta); }

    .btn-logout {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 18px;
      background: transparent;
      color: var(--terracotta);
      border: 1.5px solid var(--terracotta);
      border-radius: 999px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.875rem;
      font-weight: 500;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.2s, color 0.2s, transform 0.15s;
    }

    .btn-logout:hover {
      background: var(--terracotta);
      color: var(--white);
      transform: translateY(-2px);
    }

    /* ── Main ── */
    .main {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 24px 64px;
    }

    .page-top {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 28px;
      gap: 16px;
      flex-wrap: wrap;
    }

    .page-top h1 {
      font-family: 'Playfair Display', serif;
      font-size: 1.75rem;
      font-weight: 600;
      color: var(--text-dark);
      letter-spacing: -0.02em;
    }

    .page-top .sub {
      font-size: 0.875rem;
      color: var(--text-light);
      margin-top: 2px;
    }

    .btn-add {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 11px 22px;
      background: var(--terracotta);
      color: var(--white);
      border: none;
      border-radius: 999px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      white-space: nowrap;
    }

    .btn-add:hover {
      background: var(--terra-dark);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(192,98,47,0.25);
    }

    /* ── Table Card ── */
    .table-card {
      background: var(--white);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      box-shadow: 0 2px 16px var(--shadow);
      overflow: hidden;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    thead {
      background: var(--cream-dark);
    }

    thead th {
      padding: 14px 18px;
      font-size: 0.775rem;
      font-weight: 600;
      color: var(--text-mid);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }

    tbody tr {
      border-bottom: 1px solid var(--border);
      transition: background 0.15s;
    }

    tbody tr:last-child { border-bottom: none; }

    tbody tr:nth-child(even) { background: #fdfbf9; }

    tbody tr:hover { background: #fdf5ef; }

    td {
      padding: 14px 18px;
      font-size: 0.9rem;
      color: var(--text-dark);
      vertical-align: middle;
    }

    .badge-posisi {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 999px;
      background: #edf0ea;
      color: var(--sage);
      font-size: 0.775rem;
      font-weight: 500;
    }

    .gaji-val {
      font-weight: 500;
      color: var(--warm-brown);
    }

    /* ── Action Buttons ── */
    .act-btns {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .btn-edit {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 6px 14px;
      background: #fdf0eb;
      color: var(--terracotta);
      border: 1px solid #f0c4ae;
      border-radius: 999px;
      font-size: 0.8125rem;
      font-weight: 500;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s;
    }

    .btn-edit:hover {
      background: var(--terracotta);
      color: var(--white);
      border-color: var(--terracotta);
      transform: translateY(-2px);
    }

    .btn-del {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 6px 14px;
      background: transparent;
      color: #c0392b;
      border: 1px solid #f5b7b1;
      border-radius: 999px;
      font-size: 0.8125rem;
      font-weight: 500;
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      transition: background 0.2s, transform 0.15s;
    }

    .btn-del:hover {
      background: #c0392b;
      color: var(--white);
      border-color: #c0392b;
      transform: translateY(-2px);
    }

    /* ── Empty State ── */
    .empty-state {
      text-align: center;
      padding: 64px 24px;
    }

    .empty-state i {
      font-size: 3rem;
      color: var(--border);
      display: block;
      margin-bottom: 16px;
    }

    .empty-state p {
      color: var(--text-light);
      font-size: 0.9375rem;
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <a href="/dashboard" class="navbar-brand">
      <div class="dot"><i class="bi bi-people-fill"></i></div>
      <span>CRUD Pegawai</span>
    </a>
    <div class="navbar-right">
      <div class="nav-user">
        <i class="bi bi-person-circle"></i>
        <%= user.username %>
      </div>
      <a href="/logout" class="btn-logout">
        <i class="bi bi-box-arrow-right"></i> Keluar
      </a>
    </div>
  </nav>

  <main class="main">
    <div class="page-top">
      <div>
        <h1>Data Pegawai</h1>
        <div class="sub">Kelola seluruh informasi pegawai</div>
      </div>
      <a href="/pegawai/create" class="btn-add">
        <i class="bi bi-plus-lg"></i> Tambah Pegawai
      </a>
    </div>

    <div class="table-card">
      <% if (pegawai && pegawai.length > 0) { %>
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Nama</th>
              <th>Posisi</th>
              <th>Gaji</th>
              <th>Alamat</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% pegawai.forEach((p, i) => { %>
              <tr>
                <td><%= i + 1 %></td>
                <td><strong><%= p.nama %></strong></td>
                <td><span class="badge-posisi"><%= p.posisi %></span></td>
                <td><span class="gaji-val">Rp <%= Number(p.gaji).toLocaleString('id-ID') %></span></td>
                <td><%= p.alamat %></td>
                <td>
                  <div class="act-btns">
                    <a href="/pegawai/edit/<%= p.id %>" class="btn-edit">
                      <i class="bi bi-pencil"></i> Edit
                    </a>
                    <form action="/pegawai/delete/<%= p.id %>" method="POST" onsubmit="return confirm('Hapus pegawai ini?')">
                      <button type="submit" class="btn-del">
                        <i class="bi bi-trash3"></i> Hapus
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="empty-state">
          <i class="bi bi-inbox"></i>
          <p>Belum ada data pegawai. <a href="/pegawai/create" style="color:var(--terracotta);text-decoration:none;font-weight:500;">Tambahkan sekarang</a>.</p>
        </div>
      <% } %>
    </div>
  </main>
</body>
</html>
