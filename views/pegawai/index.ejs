<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Data Pegawai — StellarHR</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --purple: #a855f7;
      --purple-dark: #7c3aed;
      --teal: #06b6d4;
      --teal-dark: #0891b2;
      --bg1: #0a0a1a;
      --bg2: #1a0533;
      --bg3: #0d1b2a;
      --glass-bg: rgba(255,255,255,0.05);
      --glass-border: rgba(255,255,255,0.10);
      --glass-bg-hover: rgba(255,255,255,0.08);
      --text-primary: #f1f5f9;
      --text-secondary: #94a3b8;
      --text-muted: #64748b;
      --error: #f87171;
      --success: #34d399;
    }

    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      background: linear-gradient(135deg, var(--bg1) 0%, var(--bg2) 50%, var(--bg3) 100%);
      background-attachment: fixed;
      color: var(--text-primary);
    }

    .bg-orbs { position: fixed; inset: 0; pointer-events: none; z-index: 0; }
    .orb { position: absolute; border-radius: 50%; filter: blur(60px); }
    .orb-1 {
      top: -10%; left: -5%; width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(168,85,247,0.10), transparent 70%);
      animation: orbFloat 10s ease-in-out infinite;
    }
    .orb-2 {
      bottom: -10%; right: -5%; width: 450px; height: 450px;
      background: radial-gradient(circle, rgba(6,182,212,0.09), transparent 70%);
      animation: orbFloat 12s ease-in-out infinite reverse;
    }
    @keyframes orbFloat {
      0%, 100% { transform: translate(0,0); }
      33% { transform: translate(20px,-15px); }
      66% { transform: translate(-15px, 20px); }
    }

    /* Navbar */
    .navbar {
      position: sticky; top: 0; z-index: 100;
      background: rgba(10,10,26,0.75);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--glass-border);
      padding: 0 2rem; height: 64px;
      display: flex; align-items: center; justify-content: space-between;
      box-shadow: 0 4px 30px rgba(0,0,0,0.3);
    }
    .navbar::after {
      content: ''; position: absolute;
      bottom: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, rgba(168,85,247,0.4), rgba(6,182,212,0.4), transparent);
    }
    .nav-brand { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; }
    .nav-logo {
      width: 36px; height: 36px;
      background: linear-gradient(135deg, var(--purple), var(--teal));
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem; color: #fff;
      box-shadow: 0 0 15px rgba(168,85,247,0.4);
    }
    .nav-title {
      font-size: 1.1rem; font-weight: 800;
      background: linear-gradient(90deg, var(--purple), var(--teal));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .nav-actions { display: flex; align-items: center; gap: 1rem; }
    .nav-user { display: flex; align-items: center; gap: 0.5rem; color: var(--text-secondary); font-size: 0.875rem; }
    .nav-avatar {
      width: 32px; height: 32px;
      background: linear-gradient(135deg, var(--purple-dark), var(--purple));
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.8rem; font-weight: 700; color: #fff;
      box-shadow: 0 0 10px rgba(168,85,247,0.4);
    }
    .btn-logout {
      display: flex; align-items: center; gap: 0.4rem;
      padding: 0.45rem 1rem;
      background: rgba(248,113,113,0.1);
      border: 1px solid rgba(248,113,113,0.25);
      border-radius: 8px; color: #f87171;
      font-family: 'Inter', sans-serif;
      font-size: 0.8rem; font-weight: 600;
      cursor: pointer; text-decoration: none;
      transition: all 0.3s ease;
    }
    .btn-logout:hover {
      background: rgba(248,113,113,0.2);
      box-shadow: 0 0 15px rgba(248,113,113,0.3);
    }

    main {
      position: relative; z-index: 1;
      max-width: 1200px;
      margin: 0 auto;
      padding: 2.5rem 2rem;
    }

    /* Page header */
    .page-header {
      display: flex; align-items: flex-start; justify-content: space-between;
      flex-wrap: wrap; gap: 1rem;
      margin-bottom: 2.5rem;
    }
    .page-eyebrow {
      font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--teal); margin-bottom: 0.4rem;
      display: flex; align-items: center; gap: 0.4rem;
    }
    .page-eyebrow::before {
      content: ''; width: 20px; height: 2px;
      background: var(--teal); border-radius: 2px; box-shadow: 0 0 6px var(--teal);
    }
    .page-title { font-size: 1.75rem; font-weight: 800; color: var(--text-primary); letter-spacing: -0.02em; }
    .page-sub { color: var(--text-muted); font-size: 0.875rem; margin-top: 0.25rem; }

    .btn-add {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      background: linear-gradient(135deg, var(--purple-dark), var(--purple));
      border: none; border-radius: 12px;
      color: #fff; font-family: 'Inter', sans-serif;
      font-size: 0.875rem; font-weight: 600;
      cursor: pointer; text-decoration: none;
      transition: all 0.3s ease;
      box-shadow: 0 4px 20px rgba(168,85,247,0.35);
      white-space: nowrap;
    }
    .btn-add:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(168,85,247,0.55), 0 0 40px rgba(168,85,247,0.15);
    }
    .btn-add:active { transform: translateY(0); }

    /* Search bar */
    .search-bar-wrap { margin-bottom: 1.5rem; }
    .search-inner { position: relative; max-width: 420px; }
    .search-icon {
      position: absolute; left: 1rem; top: 50%; transform: translateY(-50%);
      color: var(--text-muted); font-size: 1rem; pointer-events: none;
    }
    .search-input {
      width: 100%; padding: 0.75rem 1rem 0.75rem 2.75rem;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: 12px;
      color: var(--text-primary);
      font-family: 'Inter', sans-serif; font-size: 0.875rem;
      outline: none; transition: all 0.3s;
    }
    .search-input::placeholder { color: var(--text-muted); }
    .search-input:focus {
      border-color: var(--teal);
      background: rgba(6,182,212,0.05);
      box-shadow: 0 0 0 3px rgba(6,182,212,0.12);
    }

    /* Table card */
    .table-card {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }
    .table-card::before {
      content: ''; display: block; height: 1px;
      background: linear-gradient(90deg, transparent, rgba(168,85,247,0.5), rgba(6,182,212,0.5), transparent);
    }

    table { width: 100%; border-collapse: collapse; }
    thead tr {
      background: rgba(168,85,247,0.08);
      border-bottom: 1px solid var(--glass-border);
    }
    thead th {
      padding: 1rem 1.25rem;
      text-align: left;
      font-size: 0.7rem; font-weight: 700;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--text-muted);
    }
    tbody tr {
      border-bottom: 1px solid rgba(255,255,255,0.04);
      transition: all 0.2s ease;
    }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: var(--glass-bg-hover); }
    tbody td { padding: 1rem 1.25rem; font-size: 0.875rem; color: var(--text-secondary); vertical-align: middle; }

    .employee-name {
      font-weight: 600; color: var(--text-primary);
      display: flex; align-items: center; gap: 0.625rem;
    }
    .employee-avatar {
      width: 34px; height: 34px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.75rem; font-weight: 700; color: #fff; flex-shrink: 0;
    }
    .avatar-purple { background: linear-gradient(135deg, var(--purple-dark), var(--purple)); box-shadow: 0 0 10px rgba(168,85,247,0.3); }
    .avatar-teal { background: linear-gradient(135deg, var(--teal-dark), var(--teal)); box-shadow: 0 0 10px rgba(6,182,212,0.3); }

    .badge-posisi {
      display: inline-flex; align-items: center; gap: 0.35rem;
      padding: 0.25rem 0.75rem;
      background: rgba(168,85,247,0.12);
      border: 1px solid rgba(168,85,247,0.25);
      border-radius: 20px;
      font-size: 0.75rem; font-weight: 600; color: var(--purple);
    }

    .salary-text { font-family: 'Inter', sans-serif; font-weight: 600; color: var(--success); }

    .address-text { max-width: 180px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    .actions-cell { display: flex; align-items: center; gap: 0.5rem; }
    .btn-action {
      display: inline-flex; align-items: center; gap: 0.35rem;
      padding: 0.4rem 0.875rem;
      border-radius: 8px; font-family: 'Inter', sans-serif;
      font-size: 0.78rem; font-weight: 600;
      cursor: pointer; text-decoration: none;
      border: 1px solid; transition: all 0.3s ease; white-space: nowrap;
    }
    .btn-edit {
      background: rgba(6,182,212,0.1);
      border-color: rgba(6,182,212,0.25); color: var(--teal);
    }
    .btn-edit:hover { background: rgba(6,182,212,0.2); box-shadow: 0 0 15px rgba(6,182,212,0.3); }
    .btn-delete {
      background: rgba(248,113,113,0.1);
      border-color: rgba(248,113,113,0.25); color: #f87171;
    }
    .btn-delete:hover { background: rgba(248,113,113,0.2); box-shadow: 0 0 15px rgba(248,113,113,0.3); }

    /* Empty state */
    .empty-state {
      text-align: center; padding: 4rem 2rem;
    }
    .empty-icon {
      font-size: 3rem; color: var(--text-muted); margin-bottom: 1rem;
      opacity: 0.5;
    }
    .empty-title { font-size: 1.1rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 0.5rem; }
    .empty-sub { color: var(--text-muted); font-size: 0.875rem; margin-bottom: 1.5rem; }

    /* Pagination / count */
    .table-footer {
      padding: 1rem 1.25rem;
      border-top: 1px solid var(--glass-border);
      display: flex; align-items: center; justify-content: space-between;
      font-size: 0.8rem; color: var(--text-muted);
      flex-wrap: wrap; gap: 0.5rem;
    }
    .count-badge {
      display: inline-flex; align-items: center; gap: 0.35rem;
      background: rgba(168,85,247,0.1);
      border: 1px solid rgba(168,85,247,0.2);
      border-radius: 20px; padding: 0.2rem 0.75rem;
      font-size: 0.75rem; color: var(--purple); font-weight: 600;
    }

    /* Delete modal */
    .modal-overlay {
      position: fixed; inset: 0; z-index: 200;
      background: rgba(0,0,0,0.6);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      display: flex; align-items: center; justify-content: center;
      opacity: 0; pointer-events: none; transition: opacity 0.3s;
    }
    .modal-overlay.show { opacity: 1; pointer-events: all; }
    .modal-box {
      background: rgba(10,10,26,0.95);
      border: 1px solid var(--glass-border);
      border-radius: 20px; padding: 2rem;
      max-width: 380px; width: 90%;
      box-shadow: 0 30px 60px rgba(0,0,0,0.5);
      transform: scale(0.9); transition: transform 0.3s;
      position: relative;
    }
    .modal-overlay.show .modal-box { transform: scale(1); }
    .modal-icon {
      width: 56px; height: 56px; border-radius: 16px;
      background: rgba(248,113,113,0.15);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.5rem; color: #f87171;
      margin: 0 auto 1.25rem;
      box-shadow: 0 0 20px rgba(248,113,113,0.2);
    }
    .modal-title { text-align: center; font-size: 1.1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem; }
    .modal-body { text-align: center; color: var(--text-muted); font-size: 0.875rem; margin-bottom: 1.5rem; }
    .modal-body strong { color: var(--text-secondary); }
    .modal-actions { display: flex; gap: 0.75rem; }
    .modal-cancel {
      flex: 1; padding: 0.75rem;
      background: var(--glass-bg); border: 1px solid var(--glass-border);
      border-radius: 10px; color: var(--text-secondary);
      font-family: 'Inter', sans-serif; font-size: 0.875rem; font-weight: 600;
      cursor: pointer; transition: all 0.2s;
    }
    .modal-cancel:hover { background: var(--glass-bg-hover); }
    .modal-confirm {
      flex: 1; padding: 0.75rem;
      background: linear-gradient(135deg, #dc2626, #f87171);
      border: none; border-radius: 10px; color: #fff;
      font-family: 'Inter', sans-serif; font-size: 0.875rem; font-weight: 600;
      cursor: pointer; transition: all 0.2s;
      box-shadow: 0 4px 15px rgba(220,38,38,0.4);
    }
    .modal-confirm:hover { box-shadow: 0 6px 25px rgba(220,38,38,0.6); transform: translateY(-1px); }

    footer {
      text-align: center; padding: 2rem;
      color: var(--text-muted); font-size: 0.75rem;
      position: relative; z-index: 1;
    }

    @media (max-width: 900px) {
      .address-text { max-width: 120px; }
    }
    @media (max-width: 768px) {
      .navbar { padding: 0 1rem; }
      main { padding: 2rem 1rem; }
      .page-header { flex-direction: column; }
      thead th:nth-child(4), tbody td:nth-child(4) { display: none; }
    }
    @media (max-width: 480px) {
      thead th:nth-child(3), tbody td:nth-child(3) { display: none; }
      .nav-user span { display: none; }
    }
  </style>
</head>
<body>
  <div class="bg-orbs">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div class="modal-overlay" id="deleteModal">
    <div class="modal-box">
      <div class="modal-icon"><i class="bi bi-person-x-fill"></i></div>
      <div class="modal-title">Delete Employee?</div>
      <div class="modal-body">You are about to delete <strong id="deleteNameDisplay"></strong>. This action cannot be undone.</div>
      <div class="modal-actions">
        <button class="modal-cancel" id="modalCancel">Cancel</button>
        <form id="deleteForm" method="POST" style="flex:1">
          <button type="submit" class="modal-confirm" style="width:100%">
            <i class="bi bi-trash3"></i> Delete
          </button>
        </form>
      </div>
    </div>
  </div>

  <nav class="navbar">
    <a href="/dashboard" class="nav-brand">
      <div class="nav-logo"><i class="bi bi-people-fill"></i></div>
      <span class="nav-title">StellarHR</span>
    </a>
    <div class="nav-actions">
      <div class="nav-user">
        <div class="nav-avatar"><%= user.username.charAt(0).toUpperCase() %></div>
        <span><%= user.username %></span>
      </div>
      <a href="/logout" class="btn-logout"><i class="bi bi-power"></i> Logout</a>
    </div>
  </nav>

  <main>
    <div class="page-header">
      <div>
        <div class="page-eyebrow"><i class="bi bi-person-lines-fill"></i> Management</div>
        <h1 class="page-title">Employee Records</h1>
        <p class="page-sub">Manage all your employee data in one place</p>
      </div>
      <a href="/pegawai/create" class="btn-add" id="addNewEmployeeBtn">
        <i class="bi bi-plus-lg"></i> Add Employee
      </a>
    </div>

    <div class="search-bar-wrap">
      <div class="search-inner">
        <i class="bi bi-search search-icon"></i>
        <input type="text" class="search-input" id="searchInput" placeholder="Search by name, position, or address..." />
      </div>
    </div>

    <div class="table-card">
      <% if (pegawai && pegawai.length > 0) { %>
      <table id="pegawaiTable">
        <thead>
          <tr>
            <th>#</th>
            <th>Employee</th>
            <th>Position</th>
            <th>Salary</th>
            <th>Address</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="tableBody">
          <% pegawai.forEach((p, index) => { %>
          <tr>
            <td><%= index + 1 %></td>
            <td>
              <div class="employee-name">
                <div class="employee-avatar <%= index % 2 === 0 ? 'avatar-purple' : 'avatar-teal' %>">
                  <%= p.nama ? p.nama.charAt(0).toUpperCase() : '?' %>
                </div>
                <%= p.nama %>
              </div>
            </td>
            <td><span class="badge-posisi"><i class="bi bi-briefcase-fill"></i><%= p.posisi %></span></td>
            <td class="salary-text">Rp <%= Number(p.gaji).toLocaleString('id-ID') %></td>
            <td><span class="address-text" title="<%= p.alamat %>"><%= p.alamat %></span></td>
            <td>
              <div class="actions-cell">
                <a href="/pegawai/edit/<%= p.id %>" class="btn-action btn-edit" id="editBtn-<%= p.id %>">
                  <i class="bi bi-pencil-square"></i> Edit
                </a>
                <button
                  class="btn-action btn-delete"
                  id="deleteBtn-<%= p.id %>"
                  onclick="confirmDelete(<%= p.id %>, '<%= p.nama.replace(/'/g, "\\'") %>')"
                >
                  <i class="bi bi-trash3"></i> Delete
                </button>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <div class="table-footer">
        <span class="count-badge"><i class="bi bi-people-fill"></i> <span id="countDisplay"><%= pegawai.length %></span> employees</span>
        <span>Last updated: <span id="lastUpdate"></span></span>
      </div>
      <% } else { %>
      <div class="empty-state">
        <div class="empty-icon"><i class="bi bi-person-slash"></i></div>
        <div class="empty-title">No Employees Found</div>
        <div class="empty-sub">Start by adding your first employee record</div>
        <a href="/pegawai/create" class="btn-add" style="display:inline-flex">
          <i class="bi bi-plus-lg"></i> Add First Employee
        </a>
      </div>
      <% } %>
    </div>
  </main>

  <footer><p>StellarHR &copy; <%= new Date().getFullYear() %> — Employee Management System</p></footer>

  <script>
    // Live search
    const searchInput = document.getElementById('searchInput');
    const tableBody = document.getElementById('tableBody');
    const countDisplay = document.getElementById('countDisplay');
    if (searchInput && tableBody) {
      searchInput.addEventListener('input', () => {
        const q = searchInput.value.toLowerCase();
        const rows = tableBody.querySelectorAll('tr');
        let visible = 0;
        rows.forEach(row => {
          const text = row.textContent.toLowerCase();
          const show = text.includes(q);
          row.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        if (countDisplay) countDisplay.textContent = visible;
      });
    }

    // Last update time
    const lu = document.getElementById('lastUpdate');
    if (lu) {
      lu.textContent = new Date().toLocaleTimeString('id-ID');
    }

    // Delete modal
    function confirmDelete(id, name) {
      document.getElementById('deleteNameDisplay').textContent = name;
      document.getElementById('deleteForm').action = '/pegawai/delete/' + id;
      document.getElementById('deleteModal').classList.add('show');
    }
    document.getElementById('modalCancel').addEventListener('click', () => {
      document.getElementById('deleteModal').classList.remove('show');
    });
    document.getElementById('deleteModal').addEventListener('click', (e) => {
      if (e.target === e.currentTarget) e.currentTarget.classList.remove('show');
    });
  </script>
</body>
</html>
