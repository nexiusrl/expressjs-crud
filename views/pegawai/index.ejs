<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Data Pegawai - CRUD Pegawai</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body { background-color: #f0f2f5; }
    .navbar { background: linear-gradient(135deg, #1e3c72, #2a5298); }
    .card { border: none; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
    .table thead th { background-color: #1e3c72; color: white; border: none; }
    .table tbody tr:hover { background-color: #f8f9ff; }
    .badge-posisi { background-color: #e8ecff; color: #3a5bd9; font-weight: 500; border-radius: 20px; padding: 4px 12px; }
  </style>
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/dashboard">
        <i class="bi bi-people-fill me-2"></i>CRUD Pegawai
      </a>
      <div class="navbar-nav ms-auto d-flex flex-row align-items-center gap-3">
        <a class="nav-link text-white" href="/dashboard"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a>
        <span class="text-white-50">|</span>
        <span class="text-white"><i class="bi bi-person-circle me-1"></i><%= user.username %></span>
        <a href="/logout" class="btn btn-outline-light btn-sm">
          <i class="bi bi-box-arrow-right me-1"></i>Logout
        </a>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h4 class="fw-bold mb-0">Data Pegawai</h4>
        <small class="text-muted"><%= pegawai.length %> pegawai terdaftar</small>
      </div>
      <a href="/pegawai/create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>Tambah Pegawai
      </a>
    </div>

    <div class="card">
      <div class="card-body p-0">
        <% if (pegawai.length === 0) { %>
          <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox fs-1"></i>
            <p class="mt-2">Belum ada data pegawai. <a href="/pegawai/create">Tambah sekarang</a></p>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
              <thead>
                <tr>
                  <th class="ps-4" style="width:50px">No</th>
                  <th>Nama</th>
                  <th>Posisi</th>
                  <th>Gaji</th>
                  <th>Alamat</th>
                  <th class="text-center" style="width:150px">Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% pegawai.forEach((p, i) => { %>
                <tr>
                  <td class="ps-4 text-muted"><%= i + 1 %></td>
                  <td class="fw-semibold"><%= p.nama %></td>
                  <td><span class="badge-posisi"><%= p.posisi %></span></td>
                  <td>Rp <%= Number(p.gaji).toLocaleString('id-ID') %></td>
                  <td class="text-muted" style="max-width:200px"><%= p.alamat %></td>
                  <td class="text-center">
                    <a href="/pegawai/edit/<%= p.id %>" class="btn btn-warning btn-sm me-1">
                      <i class="bi bi-pencil-fill"></i>
                    </a>
                    <form action="/pegawai/delete/<%= p.id %>" method="POST" class="d-inline"
                          onsubmit="return confirm('Hapus pegawai <%= p.nama %>? Tindakan ini tidak bisa dibatalkan.')">
                      <button type="submit" class="btn btn-danger btn-sm">
                        <i class="bi bi-trash-fill"></i>
                      </button>
                    </form>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
