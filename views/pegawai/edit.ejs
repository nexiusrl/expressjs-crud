<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Pegawai — StellarHR</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --purple: #a855f7;
      --purple-dark: #7c3aed;
      --teal: #06b6d4;
      --teal-dark: #0891b2;
      --bg1: #0a0a1a;
      --bg2: #1a0533;
      --bg3: #0d1b2a;
      --glass-bg: rgba(255,255,255,0.05);
      --glass-border: rgba(255,255,255,0.10);
      --text-primary: #f1f5f9;
      --text-secondary: #94a3b8;
      --text-muted: #64748b;
      --error: #f87171;
    }

    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      background: linear-gradient(135deg, var(--bg1) 0%, var(--bg2) 50%, var(--bg3) 100%);
      background-attachment: fixed;
      color: var(--text-primary);
    }

    .bg-orbs { position: fixed; inset: 0; pointer-events: none; z-index: 0; }
    .orb { position: absolute; border-radius: 50%; filter: blur(60px); }
    .orb-1 {
      top: -10%; right: -5%; width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(6,182,212,0.10), transparent 70%);
      animation: orbFloat 10s ease-in-out infinite;
    }
    .orb-2 {
      bottom: -10%; left: -5%; width: 450px; height: 450px;
      background: radial-gradient(circle, rgba(168,85,247,0.09), transparent 70%);
      animation: orbFloat 12s ease-in-out infinite reverse;
    }
    @keyframes orbFloat {
      0%, 100% { transform: translate(0,0); }
      33% { transform: translate(-20px, 15px); }
      66% { transform: translate(15px, -20px); }
    }

    /* Navbar */
    .navbar {
      position: sticky; top: 0; z-index: 100;
      background: rgba(10,10,26,0.75);
      backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--glass-border);
      padding: 0 2rem; height: 64px;
      display: flex; align-items: center; justify-content: space-between;
      box-shadow: 0 4px 30px rgba(0,0,0,0.3);
    }
    .navbar::after {
      content: ''; position: absolute;
      bottom: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, rgba(6,182,212,0.4), rgba(168,85,247,0.4), transparent);
    }
    .nav-brand { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; }
    .nav-logo {
      width: 36px; height: 36px;
      background: linear-gradient(135deg, var(--teal), var(--purple));
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem; color: #fff;
      box-shadow: 0 0 15px rgba(6,182,212,0.4);
    }
    .nav-title {
      font-size: 1.1rem; font-weight: 800;
      background: linear-gradient(90deg, var(--teal), var(--purple));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .nav-back {
      display: flex; align-items: center; gap: 0.4rem;
      padding: 0.45rem 1rem;
      background: var(--glass-bg); border: 1px solid var(--glass-border);
      border-radius: 8px; color: var(--text-secondary);
      font-family: 'Inter', sans-serif; font-size: 0.8rem; font-weight: 600;
      text-decoration: none; transition: all 0.3s;
    }
    .nav-back:hover {
      background: rgba(255,255,255,0.08); color: var(--text-primary);
      border-color: rgba(6,182,212,0.3);
    }

    main {
      position: relative; z-index: 1;
      max-width: 640px;
      margin: 0 auto;
      padding: 2.5rem 2rem;
    }

    .page-header { margin-bottom: 2rem; }
    .page-eyebrow {
      font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--teal); margin-bottom: 0.4rem;
      display: flex; align-items: center; gap: 0.4rem;
    }
    .page-eyebrow::before {
      content: ''; width: 20px; height: 2px;
      background: var(--teal); border-radius: 2px; box-shadow: 0 0 6px var(--teal);
    }
    .page-title { font-size: 1.75rem; font-weight: 800; letter-spacing: -0.02em; }
    .page-sub { color: var(--text-muted); font-size: 0.875rem; margin-top: 0.25rem; }

    /* Employee badge */
    .employee-badge {
      display: inline-flex; align-items: center; gap: 0.75rem;
      background: rgba(6,182,212,0.08);
      border: 1px solid rgba(6,182,212,0.2);
      border-radius: 12px; padding: 0.625rem 1rem;
      margin-bottom: 2rem;
    }
    .badge-avatar {
      width: 36px; height: 36px;
      background: linear-gradient(135deg, var(--teal-dark), var(--teal));
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.9rem; font-weight: 700; color: #fff;
      box-shadow: 0 0 12px rgba(6,182,212,0.4);
    }
    .badge-info { display: flex; flex-direction: column; }
    .badge-name { font-size: 0.875rem; font-weight: 600; color: var(--text-primary); }
    .badge-id { font-size: 0.7rem; color: var(--text-muted); }

    .glass-card {
      background: var(--glass-bg);
      backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: 24px; padding: 2.5rem;
      box-shadow: 0 25px 50px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.06);
      position: relative; overflow: hidden;
    }
    .glass-card::before {
      content: ''; position: absolute;
      top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, rgba(6,182,212,0.5), rgba(168,85,247,0.5), transparent);
    }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
    .form-group { margin-bottom: 1.25rem; }
    .form-group.full { grid-column: 1 / -1; }
    .form-label {
      display: block; font-size: 0.78rem; font-weight: 600;
      color: var(--text-secondary); margin-bottom: 0.5rem;
      letter-spacing: 0.05em; text-transform: uppercase;
    }
    .input-wrapper { position: relative; }
    .input-icon {
      position: absolute; left: 1rem; top: 50%; transform: translateY(-50%);
      color: var(--text-muted); font-size: 1rem;
      transition: color 0.3s; pointer-events: none;
    }
    .form-control {
      width: 100%; padding: 0.875rem 1rem 0.875rem 2.75rem;
      background: rgba(255,255,255,0.04); border: 1px solid var(--glass-border);
      border-radius: 12px; color: var(--text-primary);
      font-family: 'Inter', sans-serif; font-size: 0.9rem;
      outline: none; transition: all 0.3s ease;
    }
    .form-control::placeholder { color: var(--text-muted); }
    .form-control:focus {
      border-color: var(--teal);
      background: rgba(6,182,212,0.05);
      box-shadow: 0 0 0 3px rgba(6,182,212,0.15), 0 0 20px rgba(6,182,212,0.08);
    }
    .input-wrapper:focus-within .input-icon { color: var(--teal); }

    textarea.form-control { padding-top: 0.875rem; resize: vertical; min-height: 100px; }
    .textarea-wrap .input-icon { top: 1rem; transform: none; }

    .currency-prefix {
      position: absolute; left: 1rem; top: 50%; transform: translateY(-50%);
      color: var(--text-muted); font-size: 0.8rem; font-weight: 600;
      pointer-events: none; transition: color 0.3s;
    }
    .form-control.currency { padding-left: 3.5rem; }
    .input-wrapper:focus-within .currency-prefix { color: var(--teal); }

    /* Changed indicator */
    .form-control.changed {
      border-color: rgba(6,182,212,0.5) !important;
      background: rgba(6,182,212,0.06) !important;
    }

    .section-divider {
      display: flex; align-items: center; gap: 1rem;
      margin: 1.5rem 0 1.75rem;
    }
    .section-divider::before, .section-divider::after {
      content: ''; flex: 1; height: 1px; background: var(--glass-border);
    }
    .section-divider span {
      color: var(--text-muted); font-size: 0.75rem; font-weight: 600;
      white-space: nowrap; letter-spacing: 0.06em; text-transform: uppercase;
    }

    .form-actions { display: flex; gap: 1rem; margin-top: 2rem; }
    .btn-submit {
      flex: 1; padding: 0.9rem;
      background: linear-gradient(135deg, var(--teal-dark), var(--teal));
      border: none; border-radius: 12px; color: #fff;
      font-family: 'Inter', sans-serif; font-size: 0.95rem; font-weight: 600;
      cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 0.5rem;
      transition: all 0.3s ease;
      box-shadow: 0 4px 20px rgba(6,182,212,0.4);
    }
    .btn-submit:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(6,182,212,0.6), 0 0 40px rgba(6,182,212,0.15);
    }
    .btn-submit:active { transform: translateY(0); }
    .btn-cancel {
      padding: 0.9rem 1.5rem;
      background: var(--glass-bg); border: 1px solid var(--glass-border);
      border-radius: 12px; color: var(--text-secondary);
      font-family: 'Inter', sans-serif; font-size: 0.875rem; font-weight: 600;
      cursor: pointer; text-decoration: none;
      display: flex; align-items: center; gap: 0.4rem;
      transition: all 0.3s;
    }
    .btn-cancel:hover {
      background: rgba(255,255,255,0.08); color: var(--text-primary);
      border-color: rgba(6,182,212,0.25);
    }

    footer {
      text-align: center; padding: 2rem;
      color: var(--text-muted); font-size: 0.75rem;
      position: relative; z-index: 1;
    }

    @media (max-width: 640px) {
      .glass-card { padding: 2rem 1.5rem; border-radius: 20px; }
      .form-row { grid-template-columns: 1fr; }
      main { padding: 2rem 1rem; }
      .navbar { padding: 0 1rem; }
    }
  </style>
</head>
<body>
  <div class="bg-orbs">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
  </div>

  <nav class="navbar">
    <a href="/dashboard" class="nav-brand">
      <div class="nav-logo"><i class="bi bi-people-fill"></i></div>
      <span class="nav-title">StellarHR</span>
    </a>
    <a href="/pegawai" class="nav-back">
      <i class="bi bi-arrow-left"></i> Back to List
    </a>
  </nav>

  <main>
    <div class="page-header">
      <div class="page-eyebrow"><i class="bi bi-pencil-square"></i> Edit Record</div>
      <h1 class="page-title">Edit Employee</h1>
      <p class="page-sub">Update the employee information below</p>
    </div>

    <div class="employee-badge">
      <div class="badge-avatar"><%= pegawai.nama ? pegawai.nama.charAt(0).toUpperCase() : '?' %></div>
      <div class="badge-info">
        <div class="badge-name"><%= pegawai.nama %></div>
        <div class="badge-id">Employee ID: #<%= pegawai.id %></div>
      </div>
    </div>

    <div class="glass-card">
      <form action="/pegawai/edit/<%= pegawai.id %>" method="POST" id="editForm" autocomplete="off">
        <div class="form-row">
          <div class="form-group full">
            <label class="form-label" for="nama">Full Name</label>
            <div class="input-wrapper">
              <i class="bi bi-person input-icon"></i>
              <input
                type="text" id="nama" name="nama"
                class="form-control"
                value="<%= pegawai.nama %>"
                placeholder="Employee full name"
                required
              />
            </div>
          </div>

          <div class="form-group full">
            <label class="form-label" for="posisi">Position / Role</label>
            <div class="input-wrapper">
              <i class="bi bi-briefcase input-icon"></i>
              <input
                type="text" id="posisi" name="posisi"
                class="form-control"
                value="<%= pegawai.posisi %>"
                placeholder="Job position"
                required
              />
            </div>
          </div>

          <div class="form-group full">
            <label class="form-label" for="gaji">Salary (IDR)</label>
            <div class="input-wrapper">
              <span class="currency-prefix">Rp</span>
              <input
                type="number" id="gaji" name="gaji"
                class="form-control currency"
                value="<%= pegawai.gaji %>"
                placeholder="e.g. 5000000"
                min="0" required
              />
            </div>
          </div>

          <div class="form-group full">
            <label class="form-label" for="alamat">Address</label>
            <div class="input-wrapper textarea-wrap">
              <i class="bi bi-geo-alt input-icon"></i>
              <textarea
                id="alamat" name="alamat"
                class="form-control"
                placeholder="Employee address"
                required
              ><%= pegawai.alamat %></textarea>
            </div>
          </div>
        </div>

        <div class="form-actions">
          <a href="/pegawai" class="btn-cancel" id="cancelEditBtn">
            <i class="bi bi-x-lg"></i> Cancel
          </a>
          <button type="submit" class="btn-submit" id="submitEditBtn">
            <i class="bi bi-check2-circle"></i> Save Changes
          </button>
        </div>
      </form>
    </div>
  </main>

  <footer><p>StellarHR &copy; <%= new Date().getFullYear() %> — Employee Management System</p></footer>

  <script>
    const gajiInput = document.getElementById('gaji');
    gajiInput.addEventListener('input', () => {
      if (gajiInput.value < 0) gajiInput.value = 0;
    });

    // Track changed fields
    const inputs = document.querySelectorAll('#editForm .form-control');
    inputs.forEach(input => {
      const original = input.value;
      input.addEventListener('input', () => {
        if (input.value !== original) {
          input.classList.add('changed');
        } else {
          input.classList.remove('changed');
        }
      });
    });

    // Submit feedback
    const form = document.getElementById('editForm');
    const submitBtn = document.getElementById('submitEditBtn');
    form.addEventListener('submit', () => {
      submitBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Saving...';
      submitBtn.disabled = true;
      submitBtn.style.opacity = '0.8';
    });
  </script>
</body>
</html>
