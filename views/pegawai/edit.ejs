<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Pegawai — CRUD Pegawai</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=Playfair+Display:wght@400;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream:       #faf8f5;
      --cream-dark:  #f5f0e8;
      --terracotta:  #c0622f;
      --terra-dark:  #a3521f;
      --warm-brown:  #8b4513;
      --sage:        #6b7c5c;
      --text-dark:   #2c2418;
      --text-mid:    #5a4a38;
      --text-light:  #9c8878;
      --border:      #e8dfd4;
      --shadow:      rgba(139,69,19,0.08);
      --shadow-md:   rgba(139,69,19,0.14);
      --white:       #ffffff;
      --radius:      12px;
      --radius-sm:   8px;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background-color: var(--cream);
      color: var(--text-dark);
      min-height: 100vh;
    }

    /* ── Navbar ── */
    .navbar {
      background: var(--white);
      border-bottom: 2px solid var(--terracotta);
      padding: 0 32px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 12px var(--shadow);
    }

    .navbar-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }

    .navbar-brand .dot {
      width: 32px;
      height: 32px;
      background: var(--terracotta);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .navbar-brand .dot i { color: var(--white); font-size: 16px; }

    .navbar-brand span {
      font-family: 'Playfair Display', serif;
      font-size: 1.125rem;
      font-weight: 600;
      color: var(--text-dark);
    }

    .btn-back {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 18px;
      background: transparent;
      color: var(--text-mid);
      border: 1.5px solid var(--border);
      border-radius: 999px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.875rem;
      font-weight: 500;
      text-decoration: none;
      transition: border-color 0.2s, color 0.2s, transform 0.15s;
    }

    .btn-back:hover {
      border-color: var(--terracotta);
      color: var(--terracotta);
      transform: translateY(-2px);
    }

    /* ── Main ── */
    .main {
      max-width: 680px;
      margin: 0 auto;
      padding: 48px 24px 64px;
    }

    .page-header {
      margin-bottom: 32px;
    }

    .breadcrumb {
      font-size: 0.8125rem;
      color: var(--text-light);
      margin-bottom: 8px;
    }

    .breadcrumb a {
      color: var(--terracotta);
      text-decoration: none;
    }

    .page-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: 1.75rem;
      font-weight: 600;
      color: var(--text-dark);
      letter-spacing: -0.02em;
    }

    .page-header .employee-name {
      font-size: 0.9rem;
      color: var(--text-light);
      margin-top: 4px;
    }

    /* ── Form Card ── */
    .card {
      background: var(--white);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      box-shadow: 0 4px 24px var(--shadow);
      padding: 36px 32px;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .form-group {
      margin-bottom: 22px;
    }

    label {
      display: block;
      font-size: 0.8125rem;
      font-weight: 500;
      color: var(--text-mid);
      margin-bottom: 7px;
      letter-spacing: 0.01em;
    }

    .required { color: var(--terracotta); }

    .input-wrap { position: relative; }

    .input-wrap i {
      position: absolute;
      left: 13px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-light);
      font-size: 1rem;
      pointer-events: none;
    }

    input, textarea {
      width: 100%;
      padding: 11px 14px 11px 38px;
      background: var(--cream);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9375rem;
      color: var(--text-dark);
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    textarea {
      padding-top: 11px;
      resize: vertical;
      min-height: 90px;
    }

    input:focus, textarea:focus {
      border-color: var(--terracotta);
      box-shadow: 0 0 0 3px rgba(192,98,47,0.12);
      background: var(--white);
    }

    input::placeholder, textarea::placeholder { color: var(--text-light); }

    /* ── Divider ── */
    .divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 28px 0 24px;
    }

    .danger-zone-label {
      font-size: 0.775rem;
      font-weight: 600;
      color: #c0392b;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 12px;
    }

    /* ── Buttons ── */
    .form-actions {
      display: flex;
      gap: 12px;
      margin-top: 8px;
    }

    .btn-primary {
      flex: 1;
      padding: 13px;
      background: var(--terracotta);
      color: var(--white);
      border: none;
      border-radius: 999px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9375rem;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    }

    .btn-primary:hover {
      background: var(--terra-dark);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(192,98,47,0.25);
    }

    .btn-cancel {
      padding: 13px 24px;
      background: transparent;
      color: var(--text-mid);
      border: 1.5px solid var(--border);
      border-radius: 999px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9375rem;
      font-weight: 500;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      transition: border-color 0.2s, color 0.2s;
    }

    .btn-cancel:hover {
      border-color: var(--text-mid);
      color: var(--text-dark);
    }

    .btn-delete {
      width: 100%;
      padding: 11px;
      background: transparent;
      color: #c0392b;
      border: 1.5px solid #f5b7b1;
      border-radius: 999px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.875rem;
      font-weight: 500;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      transition: background 0.2s, color 0.2s, transform 0.15s;
    }

    .btn-delete:hover {
      background: #c0392b;
      color: var(--white);
      border-color: #c0392b;
      transform: translateY(-2px);
    }

    @media (max-width: 520px) {
      .form-row { grid-template-columns: 1fr; }
      .card { padding: 24px 20px; }
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <a href="/dashboard" class="navbar-brand">
      <div class="dot"><i class="bi bi-people-fill"></i></div>
      <span>CRUD Pegawai</span>
    </a>
    <a href="/pegawai" class="btn-back">
      <i class="bi bi-arrow-left"></i> Kembali
    </a>
  </nav>

  <main class="main">
    <div class="page-header">
      <div class="breadcrumb">
        <a href="/pegawai">Pegawai</a> / Edit
      </div>
      <h1>Edit Pegawai</h1>
      <div class="employee-name">ID #<%= pegawai.id %> — <%= pegawai.nama %></div>
    </div>

    <div class="card">
      <form action="/pegawai/edit/<%= pegawai.id %>" method="POST">
        <div class="form-row">
          <div class="form-group">
            <label for="nama">Nama Lengkap <span class="required">*</span></label>
            <div class="input-wrap">
              <i class="bi bi-person"></i>
              <input type="text" id="nama" name="nama" value="<%= pegawai.nama %>" required />
            </div>
          </div>
          <div class="form-group">
            <label for="posisi">Posisi / Jabatan <span class="required">*</span></label>
            <div class="input-wrap">
              <i class="bi bi-briefcase"></i>
              <input type="text" id="posisi" name="posisi" value="<%= pegawai.posisi %>" required />
            </div>
          </div>
        </div>

        <div class="form-group">
          <label for="gaji">Gaji (Rp) <span class="required">*</span></label>
          <div class="input-wrap">
            <i class="bi bi-currency-dollar"></i>
            <input type="number" id="gaji" name="gaji" value="<%= pegawai.gaji %>" min="0" required />
          </div>
        </div>

        <div class="form-group">
          <label for="alamat">Alamat <span class="required">*</span></label>
          <div class="input-wrap">
            <i class="bi bi-geo-alt" style="top:18px;transform:none;"></i>
            <textarea id="alamat" name="alamat" required><%= pegawai.alamat %></textarea>
          </div>
        </div>

        <div class="form-actions">
          <a href="/pegawai" class="btn-cancel">Batal</a>
          <button type="submit" class="btn-primary">
            <i class="bi bi-check-lg"></i> Simpan Perubahan
          </button>
        </div>
      </form>

      <hr class="divider" />

      <div class="danger-zone-label"><i class="bi bi-exclamation-triangle-fill"></i> Zona Berbahaya</div>
      <form action="/pegawai/delete/<%= pegawai.id %>" method="POST" onsubmit="return confirm('Yakin ingin menghapus pegawai ini? Tindakan ini tidak dapat dibatalkan.')">
        <button type="submit" class="btn-delete">
          <i class="bi bi-trash3-fill"></i> Hapus Pegawai Ini
        </button>
      </form>
    </div>
  </main>
</body>
</html>
