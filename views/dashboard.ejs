<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard — StellarHR</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --purple: #a855f7;
      --purple-dark: #7c3aed;
      --teal: #06b6d4;
      --teal-dark: #0891b2;
      --bg1: #0a0a1a;
      --bg2: #1a0533;
      --bg3: #0d1b2a;
      --glass-bg: rgba(255,255,255,0.05);
      --glass-border: rgba(255,255,255,0.10);
      --glass-bg-hover: rgba(255,255,255,0.08);
      --text-primary: #f1f5f9;
      --text-secondary: #94a3b8;
      --text-muted: #64748b;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      background: linear-gradient(135deg, var(--bg1) 0%, var(--bg2) 50%, var(--bg3) 100%);
      background-attachment: fixed;
      color: var(--text-primary);
    }

    /* Background orbs */
    .bg-orbs { position: fixed; inset: 0; pointer-events: none; z-index: 0; }
    .orb {
      position: absolute; border-radius: 50%;
      filter: blur(60px);
    }
    .orb-1 {
      top: -10%; left: -5%; width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(168,85,247,0.12), transparent 70%);
      animation: orbFloat 10s ease-in-out infinite;
    }
    .orb-2 {
      bottom: -10%; right: -5%; width: 450px; height: 450px;
      background: radial-gradient(circle, rgba(6,182,212,0.10), transparent 70%);
      animation: orbFloat 12s ease-in-out infinite reverse;
    }
    .orb-3 {
      top: 40%; left: 50%; transform: translate(-50%,-50%);
      width: 300px; height: 300px;
      background: radial-gradient(circle, rgba(168,85,247,0.06), transparent 70%);
      animation: orbFloat 8s ease-in-out infinite;
    }
    @keyframes orbFloat {
      0%, 100% { transform: translate(0,0); }
      33% { transform: translate(20px,-15px); }
      66% { transform: translate(-15px, 20px); }
    }
    .orb-3 { animation: orbFloat3 8s ease-in-out infinite; }
    @keyframes orbFloat3 {
      0%, 100% { transform: translate(-50%,-50%); }
      33% { transform: translate(calc(-50% + 20px), calc(-50% - 15px)); }
      66% { transform: translate(calc(-50% - 15px), calc(-50% + 20px)); }
    }

    /* Navbar */
    .navbar {
      position: sticky; top: 0; z-index: 100;
      background: rgba(10,10,26,0.75);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--glass-border);
      padding: 0 2rem;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: 0 4px 30px rgba(0,0,0,0.3);
    }
    .navbar::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(168,85,247,0.4), rgba(6,182,212,0.4), transparent);
    }
    .nav-brand {
      display: flex; align-items: center; gap: 0.75rem;
      text-decoration: none;
    }
    .nav-logo {
      width: 36px; height: 36px;
      background: linear-gradient(135deg, var(--purple), var(--teal));
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem; color: #fff;
      box-shadow: 0 0 15px rgba(168,85,247,0.4);
    }
    .nav-title {
      font-size: 1.1rem; font-weight: 800;
      background: linear-gradient(90deg, var(--purple), var(--teal));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .nav-actions { display: flex; align-items: center; gap: 1rem; }
    .nav-user {
      display: flex; align-items: center; gap: 0.5rem;
      color: var(--text-secondary); font-size: 0.875rem;
    }
    .nav-avatar {
      width: 32px; height: 32px;
      background: linear-gradient(135deg, var(--purple-dark), var(--purple));
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.8rem; font-weight: 700; color: #fff;
      box-shadow: 0 0 10px rgba(168,85,247,0.4);
    }
    .btn-logout {
      display: flex; align-items: center; gap: 0.4rem;
      padding: 0.45rem 1rem;
      background: rgba(248,113,113,0.1);
      border: 1px solid rgba(248,113,113,0.25);
      border-radius: 8px;
      color: #f87171;
      font-family: 'Inter', sans-serif;
      font-size: 0.8rem; font-weight: 600;
      cursor: pointer; text-decoration: none;
      transition: all 0.3s ease;
    }
    .btn-logout:hover {
      background: rgba(248,113,113,0.2);
      box-shadow: 0 0 15px rgba(248,113,113,0.3);
    }

    /* Main content */
    main {
      position: relative; z-index: 1;
      max-width: 1200px;
      margin: 0 auto;
      padding: 2.5rem 2rem;
    }

    /* Hero greeting */
    .hero {
      margin-bottom: 3rem;
    }
    .hero-eyebrow {
      font-size: 0.75rem; font-weight: 600;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--teal); margin-bottom: 0.5rem;
      display: flex; align-items: center; gap: 0.5rem;
    }
    .hero-eyebrow::before {
      content: '';
      width: 24px; height: 2px;
      background: var(--teal);
      border-radius: 2px;
      box-shadow: 0 0 8px var(--teal);
    }
    .hero h1 {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 800;
      line-height: 1.2;
      color: var(--text-primary);
      letter-spacing: -0.02em;
    }
    .hero h1 span {
      background: linear-gradient(90deg, var(--purple), var(--teal));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .hero-sub {
      margin-top: 0.5rem; color: var(--text-muted); font-size: 0.95rem;
    }
    .hero-time {
      margin-top: 0.25rem; color: var(--text-muted); font-size: 0.8rem;
    }

    /* Stats grid */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }
    .stat-card {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      padding: 1.75rem;
      position: relative;
      overflow: hidden;
      transition: all 0.3s ease;
      cursor: default;
    }
    .stat-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, rgba(168,85,247,0.4), transparent);
    }
    .stat-card:hover {
      transform: translateY(-4px);
      border-color: rgba(168,85,247,0.3);
      box-shadow: 0 20px 40px rgba(0,0,0,0.3), 0 0 30px rgba(168,85,247,0.15);
    }
    .stat-card.teal:hover {
      border-color: rgba(6,182,212,0.3);
      box-shadow: 0 20px 40px rgba(0,0,0,0.3), 0 0 30px rgba(6,182,212,0.15);
    }
    .stat-card.teal::before {
      background: linear-gradient(90deg, transparent, rgba(6,182,212,0.4), transparent);
    }
    .stat-icon {
      width: 48px; height: 48px;
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem; margin-bottom: 1rem;
    }
    .stat-icon.purple {
      background: rgba(168,85,247,0.15);
      color: var(--purple);
      box-shadow: 0 0 20px rgba(168,85,247,0.2);
    }
    .stat-icon.teal {
      background: rgba(6,182,212,0.15);
      color: var(--teal);
      box-shadow: 0 0 20px rgba(6,182,212,0.2);
    }
    .stat-value {
      font-size: 2.5rem; font-weight: 800;
      background: linear-gradient(90deg, var(--purple), var(--teal));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      line-height: 1; margin-bottom: 0.375rem;
    }
    .stat-label { color: var(--text-muted); font-size: 0.875rem; font-weight: 500; }
    .stat-badge {
      position: absolute; top: 1.25rem; right: 1.25rem;
      background: rgba(52,211,153,0.15);
      border: 1px solid rgba(52,211,153,0.25);
      border-radius: 20px;
      padding: 0.25rem 0.625rem;
      font-size: 0.7rem; font-weight: 600; color: #34d399;
      display: flex; align-items: center; gap: 0.25rem;
    }

    /* Quick actions */
    .section-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 1.5rem;
    }
    .section-title {
      font-size: 1.1rem; font-weight: 700; color: var(--text-primary);
    }
    .section-line {
      flex: 1; height: 1px;
      background: linear-gradient(90deg, var(--glass-border), transparent);
      margin-left: 1rem;
    }

    .actions-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.25rem;
    }
    .action-card {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: 16px;
      padding: 1.5rem;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 1rem;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }
    .action-card::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(168,85,247,0.05), rgba(6,182,212,0.05));
      opacity: 0; transition: opacity 0.3s;
    }
    .action-card:hover {
      transform: translateY(-3px);
      border-color: rgba(168,85,247,0.3);
      box-shadow: 0 12px 30px rgba(0,0,0,0.3), 0 0 20px rgba(168,85,247,0.1);
    }
    .action-card:hover::after { opacity: 1; }
    .action-icon-wrap {
      width: 52px; height: 52px; border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem; flex-shrink: 0;
      transition: all 0.3s ease; position: relative; z-index: 1;
    }
    .action-icon-wrap.purple { background: rgba(168,85,247,0.15); color: var(--purple); }
    .action-icon-wrap.teal { background: rgba(6,182,212,0.15); color: var(--teal); }
    .action-icon-wrap.green { background: rgba(52,211,153,0.15); color: #34d399; }
    .action-card:hover .action-icon-wrap.purple { box-shadow: 0 0 20px rgba(168,85,247,0.4); }
    .action-card:hover .action-icon-wrap.teal { box-shadow: 0 0 20px rgba(6,182,212,0.4); }
    .action-card:hover .action-icon-wrap.green { box-shadow: 0 0 20px rgba(52,211,153,0.4); }
    .action-content { position: relative; z-index: 1; }
    .action-title { font-size: 0.95rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.2rem; }
    .action-desc { font-size: 0.8rem; color: var(--text-muted); }
    .action-arrow {
      margin-left: auto; color: var(--text-muted); font-size: 1rem;
      transition: all 0.3s; position: relative; z-index: 1;
    }
    .action-card:hover .action-arrow { color: var(--purple); transform: translateX(4px); }

    /* Footer */
    footer {
      text-align: center; padding: 2rem;
      color: var(--text-muted); font-size: 0.75rem;
      position: relative; z-index: 1;
    }

    @media (max-width: 768px) {
      .navbar { padding: 0 1rem; }
      main { padding: 2rem 1rem; }
      .stats-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 480px) {
      .stats-grid { grid-template-columns: 1fr; }
      .nav-user span { display: none; }
    }
  </style>
</head>
<body>
  <div class="bg-orbs">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>

  <nav class="navbar">
    <a href="/dashboard" class="nav-brand">
      <div class="nav-logo"><i class="bi bi-people-fill"></i></div>
      <span class="nav-title">StellarHR</span>
    </a>
    <div class="nav-actions">
      <div class="nav-user">
        <div class="nav-avatar"><%= user.username.charAt(0).toUpperCase() %></div>
        <span><%= user.username %></span>
      </div>
      <a href="/logout" class="btn-logout">
        <i class="bi bi-power"></i> Logout
      </a>
    </div>
  </nav>

  <main>
    <div class="hero">
      <div class="hero-eyebrow"><i class="bi bi-grid-fill"></i> Overview</div>
      <h1>Welcome back, <span><%= user.username %></span> 👋</h1>
      <p class="hero-sub">Here's what's happening with your team today.</p>
      <p class="hero-time" id="currentTime"></p>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-badge"><i class="bi bi-arrow-up-short"></i> Active</div>
        <div class="stat-icon purple"><i class="bi bi-people-fill"></i></div>
        <div class="stat-value"><%= total %></div>
        <div class="stat-label">Total Employees</div>
      </div>
      <div class="stat-card teal">
        <div class="stat-icon teal"><i class="bi bi-building"></i></div>
        <div class="stat-value">1</div>
        <div class="stat-label">Departments</div>
      </div>
    </div>

    <div class="section-header">
      <div class="section-title">Quick Actions</div>
      <div class="section-line"></div>
    </div>

    <div class="actions-grid">
      <a href="/pegawai" class="action-card" id="viewEmployeesBtn">
        <div class="action-icon-wrap purple">
          <i class="bi bi-person-lines-fill"></i>
        </div>
        <div class="action-content">
          <div class="action-title">View Employees</div>
          <div class="action-desc">Browse and manage all employee records</div>
        </div>
        <i class="bi bi-arrow-right action-arrow"></i>
      </a>

      <a href="/pegawai/create" class="action-card" id="addEmployeeBtn">
        <div class="action-icon-wrap teal">
          <i class="bi bi-person-plus-fill"></i>
        </div>
        <div class="action-content">
          <div class="action-title">Add Employee</div>
          <div class="action-desc">Register a new employee to the system</div>
        </div>
        <i class="bi bi-arrow-right action-arrow"></i>
      </a>

      <a href="/logout" class="action-card" id="logoutQuickBtn">
        <div class="action-icon-wrap green">
          <i class="bi bi-shield-check"></i>
        </div>
        <div class="action-content">
          <div class="action-title">Secure Logout</div>
          <div class="action-desc">Sign out safely from this session</div>
        </div>
        <i class="bi bi-arrow-right action-arrow"></i>
      </a>
    </div>
  </main>

  <footer>
    <p>StellarHR &copy; <%= new Date().getFullYear() %> — Employee Management System</p>
  </footer>

  <script>
    function updateTime() {
      const el = document.getElementById('currentTime');
      if (el) {
        const now = new Date();
        el.textContent = now.toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })
          + ' • ' + now.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
      }
    }
    updateTime();
    setInterval(updateTime, 1000);
  </script>
</body>
</html>
